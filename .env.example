# ─── App ──────────────────────────────────────────────────────────
APP_NAME=JARVIS
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis_secret
POSTGRES_DB=jarvis_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@postgres:5432/jarvis_db
ALEMBIC_DATABASE_URL=postgresql://jarvis:jarvis_secret@postgres:5432/jarvis_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# ─── Claude API (Anthropic) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192

# ─── OpenAI (embedding text-embedding-3-small) ────────────────────
OPENAI_API_KEY=sk-...

# ─── Gemini (Google) ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ─── Recherche web ─────────────────────────────────────────────────
SERPAPI_KEY=
TAVILY_KEY=

# ─── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Spotify OAuth ─────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Chiffrement tokens OAuth (générer avec Fernet.generate_key()) ─
ENCRYPTION_KEY=

# ─── Wake word (Porcupine) ────────────────────────────────────────
# Clé gratuite sur : https://console.picovoice.ai
PORCUPINE_ACCESS_KEY=

# ─── Routing LLM ──────────────────────────────────────────────────
# Gemini par défaut (~70%) · Groq pour les requêtes simples (~20%) · Claude pour les tâches complexes (~10%)
LLM_DEFAULT=gemini
LLM_COMPLEX_THRESHOLD=200

# ─── n8n ──────────────────────────────────────────────────────────
N8N_USER=jarvis
N8N_PASSWORD=jarvis_n8n
N8N_WEBHOOK_SECRET=change-me-n8n-webhook-secret
